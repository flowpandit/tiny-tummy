{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window — no network permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "fs:default",
    "fs:allow-app-read",
    "fs:allow-app-write",
    "fs:allow-app-read-recursive",
    "fs:allow-app-write-recursive",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "dialog:default",
    "notification:default",
    "notification:allow-notify",
    "notification:allow-request-permission",
    "os:default",
    "os:allow-platform",
    "fs:allow-write-text-file"
  ]
}
